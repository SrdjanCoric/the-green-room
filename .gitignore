node_modules/
dist/
.mastra/
web/dist/
*.tsbuildinfo

# Local data: workflow snapshots, memory, scorer results, uploads, reports. The
# built knowledge index is the one exception — it ships with the app, so exclude
# the directory's children (`data/*`, not `data/`) and re-include it after the
# `*.db` rule, or the negation couldn't take effect.
data/*
*.db
*.sqlite
!data/knowledge.db

# Knowledge corpora (top-level knowledge/) are private and never ship; the app
# ships the built index at data/knowledge.db instead. Anchored so it can't catch
# src/mastra/knowledge.
/knowledge/

# Secrets
.env
.env.*
!.env.example

# Local CV inputs (personal documents, never shipped)
cv/

# Planning notes and task files (source of truth lives in the working checkout only)
plans/

# Task review output (branch-scoped, ephemeral)
reviews/
