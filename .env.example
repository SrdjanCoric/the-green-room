# Anthropic powers the interview, grading, and coaching agents.
ANTHROPIC_API_KEY=your-api-key

# OpenAI powers the coach's retrieval (RAG): the `how-to-answer` corpus is embedded
# with text-embedding-3-small, both when you run `npm run ingest` and when the coach
# queries the index. Only the coach RAG needs this; the interview itself does not.
OPENAI_API_KEY=your-openai-api-key

# Optional. Set this only on the Mastra server. ElevenLabs speaks browser interview
# questions and creates single-use Scribe tokens for direct browser dictation. The API
# key is never sent to the browser. The built-in voice and model work with this key.
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Optional server-side overrides for the spoken-question voice and TTS model.
# ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
# ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
